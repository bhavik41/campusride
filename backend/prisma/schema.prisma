generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id         String    @id @default(cuid())
  name       String
  email      String    @unique
  password   String
  phone      String?
  isStudent  Boolean   @default(false)
  university String?
  avatar     String?
  bio        String?
  role       String    @default("USER")
  createdAt  DateTime  @default(now())
  rides      Ride[]    @relation("DriverRides")
}

model Ride {
  id            String   @id @default(cuid())
  driverId      String
  driver        User     @relation("DriverRides", fields: [driverId], references: [id])
  fromCity      String
  toCity        String
  fromAddress   String?
  toAddress     String?
  departureDate DateTime
  seats         Int
  seatsLeft     Int
  pricePerSeat  Float
  rideType      String   @default("LONG_DISTANCE")
  description   String?
  status        String   @default("ACTIVE")
  createdAt     DateTime @default(now())
}
